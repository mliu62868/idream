{
  "name": "@idream/chat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Chat Service — chat/web (API+SSE) + chat/worker (generate, memory, outbox, inbox, reconcile, maintain). Owns chat.* + local file store.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "echo 'source-only (tsx runtime), no build'",
    "db:generate": "prisma generate",
    "db:apply": "DB=${DB:-idream} SUPER=${SUPER:-kk} bash ../../db/sql/apply-validate.sh"
  },
  "dependencies": {
    "@idream/shared": "workspace:*",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "bullmq": "^5.79.0",
    "ioredis": "^5.11.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@prisma/engines": "7.6.0",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "prisma": "7.6.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
