# Chat Service config (design §8). Copy to .env and fill in.
# Loaded by src/env.ts via dotenv (non-overriding: pm2/test-injected vars win).

# Postgres — MUST use the chat_service role (SELECT views + CRUD chat.*, no public).
# CHAT_DATABASE_URL wins; DATABASE_URL is the fallback. Local default = the
# OrbStack `postgres` compose service on host port 5433 (bootstrap: db/sql/*).
CHAT_DATABASE_URL=postgresql://chat_service:chat_service_change_me@localhost:5433/idream

# Redis for BullMQ queues + token streams. CHAT_REDIS_URL wins, else REDIS_URL.
CHAT_REDIS_URL=redis://127.0.0.1:6379/0
BULLMQ_PREFIX=idream:chat

# Local file store root (sessions/*.jsonl + mem/*.md). Single-writer (instances:1).
CHAT_FS_ROOT=./data/chat

# HTTP port for chat/web (API + SSE).
CHAT_PORT=3100

# BFF signing secret — MUST match main-web's CHAT_BFF_SIGNING_SECRET. Empty in
# dev/test ⇒ trust x-idream-user-id header instead of verifying a signature.
CHAT_BFF_SIGNING_SECRET=

# Chat model provider: "mock" | "openai" | "pipeline" (OpenAI-compatible endpoint).
# For local mlx, run oMLX (`omlx start`) and point at its /v1; API key is
# auth.api_key from ~/.omlx/settings.json. List models:
#   curl -H "Authorization: Bearer <key>" http://127.0.0.1:8061/v1/models
CHAT_MODEL_PROVIDER=mock
# CHAT_MODEL_BASE_URL=http://127.0.0.1:8061/v1
# CHAT_MODEL_NAME=Qwen3.5-0.8B-8bit   # or Qwen3.6-27B-oQ4-mtp for higher quality
# CHAT_MODEL_API_KEY=omlx
MODERATION_PROVIDER=mock
# MODERATION_PROVIDER=safety-gateway
# MODERATION_SERVICE_URL=https://moderation.internal.example.com
# MODERATION_API_KEY=replace-with-safety-gateway-token
# MODERATION_TIMEOUT_MS=5000

# Logging: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=info
