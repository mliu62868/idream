# iDream chat service production environment template.
# Copy into your secret manager or deployment platform. Do not commit filled values.

NODE_ENV=production
APP_ENV=production
LOG_LEVEL=info

# Chat service MUST use the chat_service database role. Do not reuse main-web's
# app DATABASE_URL; chat only reads views and writes chat.* authority tables.
CHAT_DATABASE_URL=postgresql://chat_service:replace-with-password@postgres.example.com:5432/idream

# Redis for BullMQ queues and SSE token streams. Use the same Redis deployment
# as main/gen, with the shared production queue prefix.
CHAT_REDIS_URL=redis://redis.example.com:6379/0
BULLMQ_PREFIX=idream:prod

# Single-writer local file store for chat logs and memories. Mount this path on
# durable storage if the chat process runs in an ephemeral container.
CHAT_FS_ROOT=/var/lib/idream/chat

# HTTP port for chat/web (API + SSE).
CHAT_PORT=3100

# Must exactly match main-web's CHAT_BFF_SIGNING_SECRET.
CHAT_BFF_SIGNING_SECRET=replace-with-random-chat-bff-secret

# Production chat model. "pipeline" points at the internal OpenAI-compatible
# gateway; the gateway owns vendor/model routing.
CHAT_MODEL_PROVIDER=pipeline
CHAT_MODEL_BASE_URL=https://pipeline.internal.example.com
CHAT_MODEL_NAME=chat-default
CHAT_MODEL_API_KEY=replace-with-pipeline-api-token

# Input/output moderation. Use the same safety gateway as main/gen.
CHAT_MODERATION_PROVIDER=safety-gateway
CHAT_MODERATION_SERVICE_URL=https://moderation.internal.example.com
CHAT_MODERATION_API_KEY=replace-with-safety-gateway-token
CHAT_MODERATION_TIMEOUT_MS=5000
