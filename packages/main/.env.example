DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

BETTER_AUTH_SECRET=replace-with-at-least-32-characters
INTERNAL_TOKEN=replace-with-at-least-16-characters
CRON_SECRET=replace-with-at-least-16-characters

APP_ENV=development
LOG_LEVEL=info

# Redis (shared with workers) + BullMQ prefix
REDIS_URL=redis://127.0.0.1:6379/0
BULLMQ_PREFIX=idream:dev

# HTTP port for next start (main-web)
PORT=3000

# Chat Service split (design §1/§8). Set BOTH to route /api/v1/chat/* through the
# BFF reverse proxy to the chat service instead of in-monolith chat (dev default).
# CHAT_BFF_SIGNING_SECRET must match packages/chat/.env.
# CHAT_SERVICE_URL=http://127.0.0.1:3100
# CHAT_BFF_SIGNING_SECRET=replace-with-a-shared-secret

CHAT_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
VOICE_PROVIDER=mock
MODERATION_PROVIDER=mock
PAYMENT_PROVIDER=mock
BLOB_PROVIDER=mock
AGE_VERIFICATION_PROVIDER=mock
