# DB: Postgres only. Local default = compose `postgres` service on host port 5433.
# For production, start from .env.production.example and keep filled values in
# your deployment secret manager, not in git.
# Run `docker compose up -d postgres redis`, then `npm run db:push` from packages/main.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/idream

BETTER_AUTH_SECRET=replace-with-at-least-32-characters
INTERNAL_TOKEN=replace-with-at-least-16-characters
CRON_SECRET=replace-with-at-least-16-characters

APP_ENV=development
LOG_LEVEL=info

# Redis (shared with workers) + BullMQ prefix
REDIS_URL=redis://127.0.0.1:6379/0
# MUST be identical across main / chat / gen / admin — cross-service queues
# (chat.inbound, main.inbound) are produced by one service and consumed by another;
# a mismatch silently drops every cross-service event. Use idream:${APP_ENV}
# (dev: idream:development).
BULLMQ_PREFIX=idream:development

# HTTP port for next start (main-web). The admin console is a separate service;
# see packages/admin/.env.example and ecosystem.config.js (default admin-web=3001).
PORT=3000
# MAIN_WEB_URL=http://localhost:3000
# ADMIN_WEB_URL=http://localhost:3001
# WEB_SURFACE_PROBE_REPORT=.tmp/launch-web-surface-probe.json

# Chat Service split (design §1/§8, P0-A). Chat is a HARD dependency: the
# in-monolith chat handler has been removed, so any deploy that exposes the Chat
# nav MUST set CHAT_SERVICE_URL. When it is unset, /api/v1/chat/* and
# /api/v1/messages/* return a structured 503 chat_unavailable (not a 404). Only
# test / dev smoke runs may leave it unset. CHAT_BFF_SIGNING_SECRET must match
# packages/chat/.env (shared HMAC secret for the signed BFF context).
# CHAT_SERVICE_URL=http://127.0.0.1:3100
# CHAT_BFF_SIGNING_SECRET=replace-with-a-shared-secret
# CHAT_SERVICE_PROBE_REPORT=.tmp/launch-chat-service-probe.json
# PRODUCT_CONFIG_PROBE_REPORT=.tmp/launch-product-config-probe.json

# Shared OpenAI-compatible Pipeline API for production chat/voice adapters.
# Main-web uses this when CHAT_PROVIDER=pipeline or VOICE_PROVIDER=pipeline.
# Voice may use a separate MOSS-TTS endpoint because the local sd.cpp image
# gateway does not implement /audio/speech.
# PIPELINE_API_URL=https://pipeline.internal.example.com/v1
# PIPELINE_VOICE_API_URL=http://127.0.0.1:8000/v1
# PIPELINE_API_TOKEN=replace-with-pipeline-token
# PIPELINE_VOICE_API_TOKEN=replace-with-moss-tts-token
# PIPELINE_CHAT_MODEL_DEFAULT=chat-default
# PIPELINE_IMAGE_MODEL_DEFAULT=pornmaster-zimage-turbo
# PIPELINE_VOICE_MODEL_DEFAULT=OpenMOSS/MOSS-TTS-Local-Transformer-v1.5
# Local oMLX Qwen3-TTS probes use `serena`; MOSS gateway defaults depend on the
# runner configuration.
# VOICE_MODEL_PROBE_VOICE_ID=serena
# PIPELINE_TIMEOUT_MS=60000
# PIPELINE_IMAGE_PROBE_REPORT=.tmp/launch-image-probe.json
# VOICE_MODEL_PROBE_REPORT=.tmp/launch-voice-probe.json

CHAT_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
VOICE_PROVIDER=mock
MODERATION_PROVIDER=mock
PAYMENT_PROVIDER=mock
BLOB_PROVIDER=mock
AGE_VERIFICATION_PROVIDER=mock

# Production moderation provider. Main and gen workers share these credentials.
# MODERATION_PROVIDER=safety-gateway
# MODERATION_SERVICE_URL=https://moderation.internal.example.com
# MODERATION_API_KEY=replace-with-safety-gateway-token
# MODERATION_TIMEOUT_MS=5000

# Production age verification provider. This points to an internal Go.cam
# gateway service that owns the Go.cam SDK/partner keys and returns signed
# verification URLs to main-web.
# AGE_VERIFICATION_PROVIDER=gocam
# AGE_VERIFY_SERVICE_URL=https://age.internal.example.com
# AGE_VERIFY_API_KEY=replace-with-age-gateway-token
# AGE_VERIFY_WEBHOOK_SECRET=replace-with-age-webhook-secret
# AGE_VERIFY_LINK_BACK_URL=https://ourdream.ai/age-verification/return
# AGE_VERIFY_CALLBACK_URL=https://ourdream.ai/api/v1/age-verification/webhooks/gocam
# AGE_VERIFY_TIMEOUT_MS=10000

# Production crypto checkout provider.
# PAYMENT_PROVIDER=btcpay
# BTCPAY_BASE_URL=https://btcpay.example.com
# BTCPAY_STORE_ID=replace-with-store-id
# BTCPAY_API_KEY=replace-with-greenfield-api-key
# BTCPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Private generated media storage. Use mock locally; use r2 or s3 in production.
# BLOB_PROVIDER=r2
# BLOB_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BLOB_BUCKET=idream-private-media
# BLOB_REGION=auto
# BLOB_ACCESS_KEY_ID=replace-with-access-key
# BLOB_SECRET_ACCESS_KEY=replace-with-secret-key

# Production launch guard:
# Copy packages/main/.env.production.example into your secret manager, fill real
# values, export it to an ignored file, then run:
#   bun run --filter @idream/main check:launch -- --launch-env-file .tmp/production-launch.env
# APP_ENV=production refuses mock chat/voice/moderation/payment/blob/age-verification
# providers and requires CHAT_SERVICE_URL + CHAT_BFF_SIGNING_SECRET. Keep
# APP_ENV=development for local mock QA.
