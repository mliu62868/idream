# iDream main-web production environment template.
# Copy into your secret manager or deployment platform. Do not commit filled values.

APP_ENV=production
NODE_ENV=production
LOG_LEVEL=info
PORT=3000
BETTER_AUTH_URL=https://ourdream.ai
MAIN_WEB_URL=https://ourdream.ai
ADMIN_WEB_URL=https://admin.ourdream.ai

# Data and queues
DATABASE_URL=postgresql://app:replace-with-password@postgres.example.com:5432/idream
REDIS_URL=redis://redis.example.com:6379/0
BULLMQ_PREFIX=idream:prod

# Core service secrets. Generate fresh values with:
#   bun run --silent launch:secrets
BETTER_AUTH_SECRET=replace-with-random-32-byte-secret
INTERNAL_TOKEN=replace-with-random-internal-token
CRON_SECRET=replace-with-random-cron-secret
CHAT_BFF_SIGNING_SECRET=replace-with-random-chat-bff-secret
CHAT_SERVICE_PROBE_REPORT=.tmp/launch-chat-service-probe.json
CHAT_SERVICE_PROBE_MAX_AGE_MINUTES=1440
PRODUCT_CONFIG_PROBE_REPORT=.tmp/launch-product-config-probe.json
PRODUCT_CONFIG_PROBE_MAX_AGE_MINUTES=1440
WEB_SURFACE_PROBE_REPORT=.tmp/launch-web-surface-probe.json
WEB_SURFACE_PROBE_MAX_AGE_MINUTES=1440

# Split chat service. CHAT_PROVIDER is main-web's adapter. CHAT_MODEL_* is the
# packages/chat runtime model config; keep both if one env file feeds all services.
CHAT_SERVICE_URL=https://chat.internal.example.com
CHAT_PROVIDER=pipeline
CHAT_DATABASE_URL=postgresql://chat_service:replace-with-password@postgres.example.com:5432/idream
CHAT_FS_ROOT=/var/lib/idream/chat
CHAT_MODEL_PROVIDER=pipeline
CHAT_MODEL_BASE_URL=https://pipeline.internal.example.com
CHAT_MODEL_NAME=chat-default
CHAT_MODEL_API_KEY=replace-with-pipeline-api-token
CHAT_MODEL_PROBE_REPORT=.tmp/launch-chat-probe.json
CHAT_MODEL_PROBE_MAX_AGE_MINUTES=1440
CHAT_MODERATION_PROVIDER=safety-gateway

# Shared OpenAI-compatible pipeline gateway. Product services call this stable
# API; sd.cpp, ComfyUI, MLX, and model files remain behind the gateway.
PIPELINE_API_URL=https://pipeline.internal.example.com
PIPELINE_VOICE_API_URL=https://moss-tts.internal.example.com/v1
PIPELINE_API_TOKEN=replace-with-pipeline-api-token
PIPELINE_VOICE_API_TOKEN=replace-with-moss-tts-api-token
PIPELINE_CHAT_MODEL_DEFAULT=chat-default
PIPELINE_VOICE_MODEL_DEFAULT=OpenMOSS/MOSS-TTS-Local-Transformer-v1.5
PIPELINE_IMAGE_MODEL_DEFAULT=pornmaster-zimage-turbo
PIPELINE_VIDEO_MODEL_DEFAULT=video-default
PIPELINE_TIMEOUT_MS=60000
PIPELINE_IMAGE_PROBE_REPORT=.tmp/launch-image-probe.json
PIPELINE_IMAGE_PROBE_MAX_AGE_MINUTES=1440
VOICE_MODEL_PROBE_REPORT=.tmp/launch-voice-probe.json
VOICE_MODEL_PROBE_MAX_AGE_MINUTES=1440

# Provider switches required by the production launch gate
VOICE_PROVIDER=pipeline
MODERATION_PROVIDER=safety-gateway
PAYMENT_PROVIDER=btcpay
BLOB_PROVIDER=r2
AGE_VERIFICATION_PROVIDER=gocam
GEN_IMAGE_PROVIDER=pipeline
GEN_VIDEO_PROVIDER=pipeline

# Safety gateway. This must be independent from image/chat generation.
MODERATION_SERVICE_URL=https://moderation.internal.example.com
MODERATION_API_KEY=replace-with-safety-gateway-token
MODERATION_TIMEOUT_MS=5000
SAFETY_GATEWAY_PROBE_REPORT=.tmp/launch-safety-probe.json
SAFETY_GATEWAY_PROBE_MAX_AGE_MINUTES=1440

# Age verification gateway. The gateway owns Go.cam SDK/partner credentials.
AGE_VERIFY_SERVICE_URL=https://age.internal.example.com
AGE_VERIFY_API_KEY=replace-with-age-gateway-token
AGE_VERIFY_WEBHOOK_SECRET=replace-with-age-webhook-secret
AGE_VERIFY_LINK_BACK_URL=https://ourdream.ai/age-verification/return
AGE_VERIFY_CALLBACK_URL=https://ourdream.ai/api/v1/age-verification/webhooks/gocam
AGE_VERIFY_TIMEOUT_MS=10000
AGE_VERIFICATION_PROBE_REPORT=.tmp/launch-age-probe.json
AGE_VERIFICATION_PROBE_MAX_AGE_MINUTES=1440

# BTCPay Greenfield checkout
BTCPAY_BASE_URL=https://btcpay.example.com
BTCPAY_STORE_ID=replace-with-store-id
BTCPAY_API_KEY=replace-with-greenfield-api-key
BTCPAY_WEBHOOK_SECRET=replace-with-webhook-secret
PAYMENT_PROVIDER_PROBE_REPORT=.tmp/launch-payment-probe.json
PAYMENT_PROVIDER_PROBE_MAX_AGE_MINUTES=1440

# Private generated media storage. Use R2 or another S3-compatible provider.
BLOB_ENDPOINT=https://account-id.r2.cloudflarestorage.com
BLOB_BUCKET=idream-private-media
BLOB_REGION=auto
BLOB_ACCESS_KEY_ID=replace-with-access-key
BLOB_SECRET_ACCESS_KEY=replace-with-secret-key
BLOB_STORAGE_PROBE_REPORT=.tmp/launch-blob-probe.json
BLOB_STORAGE_PROBE_MAX_AGE_MINUTES=1440

# Observability
SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
