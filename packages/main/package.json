{
  "name": "@idream/main",
  "version": "0.3.1",
  "private": true,
  "description": "Clone any website into a clean, modern Next.js codebase using AI coding agents",
  "author": "JCodesMore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCodesMore/ai-website-cloner-template.git"
  },
  "homepage": "https://github.com/JCodesMore/ai-website-cloner-template",
  "bugs": {
    "url": "https://github.com/JCodesMore/ai-website-cloner-template/issues"
  },
  "keywords": [
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:sqlite": "DB_PROVIDER=sqlite vitest run",
    "test:postgres": "DB_PROVIDER=postgresql vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:provider": "node scripts/db-provider.mjs",
    "db:generate": "npm run db:provider && prisma generate",
    "db:push": "node scripts/db-push.mjs",
    "db:migrate:dev": "DB_PROVIDER=postgresql npm run db:provider && prisma migrate dev",
    "db:migrate:deploy": "DB_PROVIDER=postgresql npm run db:provider && prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "start:finalizer": "tsx src/processes/finalizer.ts",
    "start:event-consumer": "tsx src/processes/event-consumer.ts"
  },
  "dependencies": {
    "@idream/shared": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-better-sqlite3": "7.6.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "better-auth": "^1.6.18",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.79.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@prisma/engines": "7.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "7.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
