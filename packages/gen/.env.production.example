# iDream generation workers production environment template.
# Copy into your secret manager or deployment platform. Do not commit filled values.

NODE_ENV=production
APP_ENV=production

# Queues
GEN_REDIS_URL=redis://redis.example.com:6379/0
BULLMQ_PREFIX=idream:prod

# Providers. Generation workers never load safetensors directly; they call the
# internal OpenAI-compatible pipeline gateway.
GEN_IMAGE_PROVIDER=pipeline
GEN_VIDEO_PROVIDER=pipeline
GEN_MODERATION_PROVIDER=safety-gateway

# Pipeline gateway
PIPELINE_API_URL=https://pipeline.internal.example.com
PIPELINE_API_TOKEN=replace-with-pipeline-api-token
PIPELINE_IMAGE_MODEL_DEFAULT=pornmaster-zimage-turbo
PIPELINE_VIDEO_MODEL_DEFAULT=video-default
PIPELINE_IMAGE_SIZE_DEFAULT=1024x1024
PIPELINE_TIMEOUT_MS=360000

# Internal sd.cpp gateway runner settings when this package hosts the gateway.
# If the diffusion weights are converted for sd.cpp, set
# SDCPP_CONVERTED_DIFFUSION_MODEL and keep SDCPP_SOURCE_MODEL pointing at the
# original safetensors for provenance.
# SDCPP_IMAGE_MODEL_ID=pornmaster-zimage-turbo
# SDCPP_SOURCE_MODEL=/models/pornmasterZImage_turboV35Bf16.safetensors
# SDCPP_CONVERTED_DIFFUSION_MODEL=/models/pornmasterZImage_turboV35Bf16.gguf
# SDCPP_CLI=/opt/stable-diffusion.cpp/sd-cli
# SDCPP_LLM=/models/z-image-components/Qwen3-4B-Instruct-2507-Q4_K_M.gguf
# SDCPP_VAE=/models/z-image-components/vae/ae.safetensors

# Safety gateway shared with main-web
MODERATION_SERVICE_URL=https://moderation.internal.example.com
MODERATION_API_KEY=replace-with-safety-gateway-token
MODERATION_TIMEOUT_MS=5000

# Private generated media storage. Must match main-web storage settings so
# generated assets can be viewed and downloaded through /user-content.
GEN_BLOB_PROVIDER=r2
BLOB_ENDPOINT=https://account-id.r2.cloudflarestorage.com
BLOB_BUCKET=idream-private-media
BLOB_REGION=auto
BLOB_ACCESS_KEY_ID=replace-with-access-key
BLOB_SECRET_ACCESS_KEY=replace-with-secret-key
