# Generation Service config (gen/image, gen/video). Copy to .env and fill in.
# Loaded by src/env.ts via dotenv (non-overriding).

# Redis for BullMQ queues. GEN_REDIS_URL wins, else REDIS_URL.
GEN_REDIS_URL=redis://127.0.0.1:6379/0
BULLMQ_PREFIX=idream:gen

# Root dir the mock blob store writes generated assets under.
BLOB_ROOT=./data/gen-blob

# Providers (only "mock" wired today). GEN_*_PROVIDER wins, else *_PROVIDER.
GEN_IMAGE_PROVIDER=mock
GEN_VIDEO_PROVIDER=mock
