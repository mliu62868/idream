# Generation Service config (gen/image, gen/video). Copy to .env and fill in.
# For production, start from .env.production.example and keep filled values in
# your deployment secret manager, not in git.
# Loaded by src/env.ts via dotenv (non-overriding).

# Redis for BullMQ queues. GEN_REDIS_URL wins, else REDIS_URL.
GEN_REDIS_URL=redis://127.0.0.1:6379/0
BULLMQ_PREFIX=idream:gen

# Root dir the mock blob store writes generated assets under.
BLOB_ROOT=./data/gen-blob

# Private generated media storage. GEN_BLOB_PROVIDER wins, else BLOB_PROVIDER.
# Production workers must use r2 or s3 so generated assets persist outside the
# worker filesystem.
GEN_BLOB_PROVIDER=mock
# BLOB_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BLOB_BUCKET=idream-private-media
# BLOB_REGION=auto
# BLOB_ACCESS_KEY_ID=replace-with-access-key
# BLOB_SECRET_ACCESS_KEY=replace-with-secret-key

# Providers. GEN_*_PROVIDER wins, else *_PROVIDER.
# Production image workers must use pipeline and must set PIPELINE_API_URL.
# Local ComfyUI/Z-Image runners should sit behind that pipeline API; do not load
# large safetensors directly in this Node worker.
GEN_IMAGE_PROVIDER=mock
GEN_VIDEO_PROVIDER=mock
GEN_MODERATION_PROVIDER=mock

# Production moderation provider. GEN_MODERATION_PROVIDER wins, else
# MODERATION_PROVIDER. Use the same gateway main-web uses so generation input
# and output gates share policy decisions.
# GEN_MODERATION_PROVIDER=safety-gateway
# MODERATION_SERVICE_URL=https://moderation.internal.example.com
# MODERATION_API_KEY=replace-with-safety-gateway-token
# MODERATION_TIMEOUT_MS=5000

# Example production/sandbox image pipeline:
# GEN_IMAGE_PROVIDER=pipeline
# PIPELINE_API_URL=http://127.0.0.1:8091/images/generations
# PIPELINE_API_TOKEN=replace-with-pipeline-token
# PIPELINE_IMAGE_MODEL_DEFAULT=pornmaster-zimage-turbo
# PIPELINE_VIDEO_MODEL_DEFAULT=video-default
# PIPELINE_IMAGE_SIZE_DEFAULT=512x512 # optional local smoke-probe override
#
# Local sd.cpp gateway defaults. The gateway uses the real source model below
# unless SDCPP_CONVERTED_DIFFUSION_MODEL or SDCPP_DIFFUSION_MODEL is set.
# SDCPP_IMAGE_MODEL_ID=pornmaster-zimage-turbo
# SDCPP_CLI=/Users/kk/code/sdcpp/sd-cli
# SDCPP_SOURCE_MODEL=/Users/kk/Downloads/pornmasterZImage_turboV35Bf16.safetensors
# SDCPP_CONVERTED_DIFFUSION_MODEL=
# SDCPP_LLM=/Users/kk/.localai/models/z-image-components/Qwen3-4B-Instruct-2507-Q4_K_M.gguf
# SDCPP_VAE=/Users/kk/.localai/models/z-image-components/split_files/vae/ae.safetensors
# SDCPP_STEPS=8
# SDCPP_MAX_COUNT=1
# SDCPP_TIMEOUT_MS=300000
#
# Preflight the provider + blob boundary without touching Redis/main DB:
# bun run probe:image -- --prompt "cinematic portrait" --count 1
