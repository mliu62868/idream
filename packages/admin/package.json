{
  "name": "@idream/admin",
  "version": "0.3.1",
  "private": true,
  "description": "iDream Admin Console — independently deployed internal control-plane service.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "npm run db:generate && next build && node ../../scripts/prepare-next-standalone.mjs packages/admin",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "db:generate": "prisma generate --schema ../main/prisma/schema.prisma"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@idream/shared": "workspace:*",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "better-auth": "^1.6.18",
    "bullmq": "^5.79.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/engines": "7.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "7.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5"
  }
}
