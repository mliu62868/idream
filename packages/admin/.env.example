# Admin Console service. Use the same database and auth secrets as packages/main.
#
# Local dev login (APP_ENV != production only): open http://localhost:3001/admin
# and use a built-in account below — no signup needed. Requires the dev DB to be
# seeded first: `cd packages/main && npm run db:seed`.
#   admin   / admin123     -> role: admin   (full access)
#   support / support123   -> role: support (read-only + tickets)
# Accounts live in packages/main/src/server/admin/dev-login-accounts.ts.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/idream

BETTER_AUTH_SECRET=replace-with-at-least-32-characters
INTERNAL_TOKEN=replace-with-at-least-16-characters
CRON_SECRET=replace-with-at-least-16-characters

APP_ENV=development
LOG_LEVEL=info

# HTTP port for next start (admin-web)
PORT=3001

# Keep this aligned with the public product origin that issues auth sessions.
BETTER_AUTH_URL=http://localhost:3000

REDIS_URL=redis://127.0.0.1:6379/0
BULLMQ_PREFIX=idream:dev

CHAT_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
VOICE_PROVIDER=mock
MODERATION_PROVIDER=mock
PAYMENT_PROVIDER=mock
BLOB_PROVIDER=mock
AGE_VERIFICATION_PROVIDER=mock
