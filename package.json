{
  "name": "idream",
  "version": "0.3.1",
  "private": true,
  "description": "iDream — AI companion platform (monorepo). main-web + chat service + gen workers, split by execution-time SLA.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "turbo run lint typecheck build",
    "dev": "pnpm --filter @idream/main dev",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
